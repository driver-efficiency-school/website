# Contact Information
VITE_CONTACT_EMAIL=support@efficiver.com
VITE_CONTACT_PHONE=
VITE_CONTACT_WEBSITE=https://www.efficiver.com

# Social Media Links (Leave empty to hide)
VITE_SOCIAL_INSTAGRAM=
VITE_SOCIAL_TIKTOK=
VITE_SOCIAL_LINKEDIN=

# Feature Toggles
VITE_SHOW_NEWSLETTER=true
VITE_SHOW_CONTACT=true

# App Links
VITE_APP_STORE_LINK=https://apps.apple.com/app/efficiver/id6754255974

# Share Buttons (Set to false to hide)
VITE_SHARE_ON_X=true
VITE_SHARE_ON_LINKEDIN=true
VITE_SHARE_ON_REDDIT=true
VITE_SHARE_NATIVE=true

# Pricing - Set to false to show "In-App Purchase" instead of "Free (Launch Offer)" for Eco Master
VITE_LAUNCH_OFFER_ECO_MASTER=true

# Content Configuration
VITE_EXIT_POPUP_SAVINGS="$300,000+ in Fuel Costs"

# API Configuration
VITE_EMAIL_API_BASE_URL=https://email.efficiency.school/api/v1

# Platform Links (Leave empty to show "Coming Soon")
VITE_PLAY_STORE_LINK=
VITE_APPLE_WATCH_LINK=
VITE_ANDROID_WATCH_LINK=
VITE_DASHBOARD_LINK=
