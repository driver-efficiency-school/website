{
  "name": "website-ed",
  "description": "Efficiver Website",
  "version": "1.0.14",
  "author": {
    "name": "Dhamodharan Krishnan",
    "email": "info@digidhamu.com",
    "url": "https://www.efficiver.com"
  },
  "keywords": [
    "vue",
    "typescript",
    "tailwind",
    "landing-page",
    "template",
    "responsive-design"
  ],
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/bump-version.mjs",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "lint:check": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "type-check": "vue-tsc --noEmit",
    "lint-staged": "lint-staged",
    "ci": "npm run lint:check && npm run type-check && npm run format:check",
    "prepare": "husky"
  },
  "dependencies": {
    "@selemondev/vue3-marquee": "^0.0.8",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^11.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel": "^8.3.0",
    "embla-carousel-vue": "^8.6.0",
    "lucide-vue-next": "^0.452.0",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vee-validate": "^4.13.2",
    "vue": "^3.5.12",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^20.19.25",
    "@vitejs/plugin-vue": "^5.2.4",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.6.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^6.4.1",
    "vue-tsc": "^2.2.12"
  },
  "lint-staged": {
    "*.{vue,js,jsx,cjs,mjs,ts,tsx,cts,mts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,sass,html,json,md}": [
      "prettier --write"
    ]
  }
}
