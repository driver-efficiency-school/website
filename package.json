{
  "name": "website-ed",
  "description": "Efficiver Website",
  "version": "1.2.1",
  "author": {
    "name": "Dhamodharan Krishnan",
    "email": "info@digidhamu.com",
    "url": "https://www.efficiver.com"
  },
  "keywords": [
    "vue",
    "typescript",
    "tailwind",
    "landing-page",
    "template",
    "responsive-design"
  ],
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/bump-version.mjs",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "lint:check": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "type-check": "vue-tsc --noEmit",
    "lint-staged": "lint-staged",
    "ci": "npm run lint:check && npm run type-check && npm run format:check",
    "prepare": "husky"
  },
  "dependencies": {
    "@selemondev/vue3-marquee": "^1.4.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel": "^8.6.0",
    "embla-carousel-vue": "^8.6.0",
    "lucide-vue-next": "^1.0.0",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.34",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vue-tsc": "^3.3.1"
  },
  "lint-staged": {
    "*.{vue,js,jsx,cjs,mjs,ts,tsx,cts,mts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,sass,html,json,md}": [
      "prettier --write"
    ]
  }
}
